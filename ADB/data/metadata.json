{
  "@context": [
    "http://www.w3.org/ns/csvw",
    {
      "@language": "en"
    }
  ],
  "dc:conformsTo": "http://cldf.clld.org/v1.0/terms.rdf#Generic",
  "tables": [
    {
      "url": "languages.csv",
      "dc:conformsTo": "http://cldf.clld.org/v1.0/terms.rdf#LanguageTable",
      "tableSchema": {
        "columns": [
          {
            "name": "language_id",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#id"
          },
          {
            "name": "Name",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#name"
          },
          {
            "name": "Macroarea"
          },
          {
            "name": "Latitude",
            "datatype": "decimal",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#latitude"
          },
          {
            "name": "Longitude",
            "datatype": "decimal",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#longitude"
          },
          {
            "name": "Glottocode",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#glottocode"
          },
          {
            "name": "ISO639P3code",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#iso639P3code"
          },
          {
            "name": "Family_name"
          },
          {
            "name": "Family_level_ID"
          }
        ],
        "primaryKey": "language_id",
        "foreignKeys": []
      }
    },
    {
      "url": "frames.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "frame_id",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#id"
          },
          {
            "name": "frame"
          }
        ],
        "primaryKey": "frame_id",
        "foreignKeys": []
      }
    },
    {
      "url": "frames_concepticon.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "frame_id",
            "required": true
          },
          {
            "name": "concepticon_id",
            "datatype": "integer"
          },
          {
            "name": "concepticon"
          }
        ],
        "primaryKey": "concepticon_id",
        "foreignKeys": [
          {
            "columnReference": "frame_id",
            "reference": {
              "resource": "frames.csv",
              "columnReference": "frame_id"
            }
          }
        ]
      }
    },
    {
      "url": "groups.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "group_id",
            "required": true
          },
          {
            "name": "language_id"
          },
          {
            "name": "frame_id"
          },
          {
            "name": "term"
          }
        ],
        "primaryKey": "group_id",
        "foreignKeys": [
          {
            "columnReference": "language_id",
            "reference": {
              "resource": "languages.csv",
              "columnReference": "language_id"
            }
          },
          {
            "columnReference": "frame_id",
            "reference": {
              "resource": "frames.csv",
              "columnReference": "frame_id"
            }
          }
        ]
      }
    },
    {
      "url": "lexemes.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "lexeme_id",
            "required": true
          },
          {
            "name": "group_id"
          },
          {
            "name": "lexeme"
          },
          {
            "name": "russian"
          }
        ],
        "primaryKey": "lexeme_id",
        "foreignKeys": [
          {
            "columnReference": "group_id",
            "reference": {
              "resource": "groups.csv",
              "columnReference": "group_id"
            }
          }
        ]
      }
    },
    {
      "url": "meanings.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "meaning_id",
            "required": true
          },
          {
            "name": "order",
            "datatype": "integer"
          },
          {
            "name": "meaning"
          }
        ],
        "primaryKey": "meaning_id",
        "foreignKeys": []
      }
    },
    {
      "url": "examples.csv",
      "dc:conformsTo": "http://cldf.clld.org/v1.0/terms.rdf#ExampleTable",
      "tableSchema": {
        "columns": [
          {
            "name": "example_id",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#id",
            "datatype": "string"
          },
          {
            "name": "language_id",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#languageReference",
            "datatype": "string"
          },
          {
            "name": "primary_text",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#primaryText",
            "dc:description": "The example text in the source language."
          },
          {
            "name": "analyzed_word",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#analyzedWord",
            "dc:description": "The sequence of words of the primary text to be aligned with glosses",
            "dc:extent": "multivalued",
            "separator": "\t"
          },
          {
            "name": "gloss",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#gloss",
            "dc:description": "The sequence of glosses aligned with the words of the primary text",
            "dc:extent": "multivalued",
            "separator": "\t"
          },
          {
            "name": "translated_text",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#translatedText",
            "dc:extent": "singlevalued",
            "dc:description": "The translation of the example text in a meta language"
          },
          {
            "name": "meta_language_id",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#metaLanguageReference",
            "dc:description": "References the language of the translated text",
            "datatype": "string"
          },
          {
            "name": "lgr_conformance",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#lgrConformance",
            "dc:description": "The level of conformance of the example with the Leipzig Glossing Rules",
            "datatype": {
              "base": "string",
              "format": "WORD_ALIGNED|MORPHEME_ALIGNED"
            }
          },
          {
            "name": "grammaticality_judgement",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#grammaticalityJudgement",
            "dc:description": "A judgement about the (un)grammaticality of the example.",
            "datatype": {
              "base": "boolean", "format": "Ok|*"
            }
          }
        ],
        "primaryKey": "example_id",
        "foreignKeys": [
          {
            "columnReference": "language_id",
            "reference": {
              "resource": "languages.csv",
              "columnReference": "language_id"
            }
          },
          {
            "columnReference": "meta_language_id",
            "reference": {
              "resource": "languages.csv",
              "columnReference": "language_id"
            }
          }
        ]
      }
    },
    {
      "url": "lexeme_meaning.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "lexeme_id"
          },
          {
            "name": "meaning_id"
          }
        ],
        "primaryKey": ["lexeme_id", "meaning_id"],
        "foreignKeys": [
          {
            "columnReference": "lexeme_id",
            "reference": {
              "resource": "lexemes.csv",
              "columnReference": "lexeme_id"
            }
          },
          {
            "columnReference": "meaning_id",
            "reference": {
              "resource": "meanings.csv",
              "columnReference": "meaning_id"
            }
          }
        ]
      }
    },
    {
      "url": "lexeme_meaning_example.csv",
      "tableSchema": {
        "columns": [
          {
            "name": "lexeme_id",
            "required": true
          },
          {
            "name": "meaning_id",
            "required": true
          },
          {
            "name": "example_id",
            "required": true,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#exampleReference"
          },
          {
            "name": "position",
            "required": false,
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#position",
            "datatype": {
              "base": "string",
              "format": "\\d+(:\\d+)?"
            },
            "dc:extent": "multivalued",
            "separator": ";"
          }
        ],
        "primaryKey": ["lexeme_id", "meaning_id", "example_id"],
        "foreignKeys": [
          {
            "columnReference": "lexeme_id",
            "reference": {
              "resource": "lexemes.csv",
              "columnReference": "lexeme_id"
            }
          },
          {
            "columnReference": "meaning_id",
            "reference": {
              "resource": "meanings.csv",
              "columnReference": "meaning_id"
            }
          },
          {
            "columnReference": "example_id",
            "reference": {
              "resource": "examples.csv",
              "columnReference": "example_id"
            }
          }
        ]
      }
    }
  ]
}